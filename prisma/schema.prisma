generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matricule   Int                     @unique
  password    String                  @map("password")
  role        String
  phone       String?
  email       String?                 @unique
  microsoftId String?                 @unique @map("microsoft_id")
  enabled     Boolean                 @default(true)
  locked      Boolean                 @default(false)
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  person      Person?
  photo       UserPhoto?
  documents   ChantierDocumentation[]

  @@map("user_table")
}

model Person {
  id              String         @id @db.Uuid
  lastName        String         @map("last_name")
  firstName       String?        @map("first_name")
  gender          String?
  user            User           @relation(fields: [id], references: [id], onDelete: Cascade)
  idEtablissement String?        @map("id_etablissement") @db.Uuid
  etablissement   Etablissement? @relation(fields: [idEtablissement], references: [id])

  @@map("person")
}

model UserPhoto {
  id             String   @id @db.Uuid
  matricule      Int?     @unique
  profilePicture String?  @map("profile_picture")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("user_photo")
}

// ── Chantiers ─────────────────────────────────────────────────────────────────

model Chantier {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codeOTP           Int                     @unique @map("otp")
  name              String?                 @unique
  description       String?                 @map("description_otp") @db.VarChar(255)
  codeAgenceSap     String?                 @map("code_agence_sap") @db.VarChar(20)
  team              String?
  client            String?
  address           String?
  progress          Decimal                 @default(0) @map("progress") @db.Decimal(7, 2)
  status            ProcessStatusEnum       @default(Initialise)
  chantierDetailsId String?                 @map("chantier_details_id") @db.Uuid
  matrResponsable   String?                 @map("matr_responsable") @db.VarChar(20)
  nomResponsable    String?                 @map("nom_responsable") @db.VarChar(150)
  matrDemandeur     String?                 @map("matr_demandeur") @db.VarChar(20)
  nomDemandeur      String?                 @map("nom_demandeur") @db.VarChar(150)
  adresseChantier   String?                 @map("adresse_chantier")
  idClient          String?                 @map("id_client") @db.VarChar(20)
  nomClient         String?                 @map("nom_client") @db.VarChar(150)
  contactSite       String?                 @map("contact_site") @db.VarChar(150)
  dateDebut         DateTime?               @map("date_debut") @db.Date
  facturationIni    Decimal?                @map("facturation_ini") @db.Decimal(15, 2)
  autresDepensesIni Decimal?                @map("autres_depenses_ini") @db.Decimal(15, 2)
  materielIni       Decimal?                @map("materiel_ini") @db.Decimal(15, 2)
  fournituresIni    Decimal?                @map("fournitures_ini") @db.Decimal(15, 2)
  mainOeuvreIni     Decimal?                @map("main_oeuvre_ini") @db.Decimal(15, 2)
  facturationVld    Decimal?                @map("facturation_vld") @db.Decimal(15, 2)
  autresDepensesVld Decimal?                @map("autres_depenses_vld") @db.Decimal(15, 2)
  materielVld       Decimal?                @map("materiel_vld") @db.Decimal(15, 2)
  fournituresVld    Decimal?                @map("fournitures_vld") @db.Decimal(15, 2)
  mainOeuvreVld     Decimal?                @map("main_oeuvre_vld") @db.Decimal(15, 2)
  typeProjet        String?                 @map("type_projet") @db.VarChar(100)
  segmentNeu        String?                 @map("segment_neu") @db.VarChar(10)
  segmentFfb        String?                 @map("segment_ffb") @db.VarChar(10)
  zoneOtp           String?                 @map("zone_otp") @db.VarChar(10)
  numDevis          String?                 @map("num_devis") @db.VarChar(50)
  dateSynchroSap    DateTime?               @map("date_synchro_sap") @db.Timestamp(6)
  idAgence          String?                 @map("id_agence") @db.Uuid
  idAo              String?                 @map("id_ao") @db.Uuid
  agence            Agence?                 @relation(fields: [idAgence], references: [id])
  ao                Ao?                     @relation(fields: [idAo], references: [id])
  chantierDetails   ChantierDetails?        @relation(fields: [chantierDetailsId], references: [id])
  intervenants      ChantierIntervenant[]
  actions           ChantierAction[]
  documentation     ChantierDocumentation[]
  interventions     Intervention[]
  documentations    Documentation[]
  folders           Folder[]
  requiredDocs      ChantierRequiredDoc[]
  sharedDocs        ChantierSharedDoc[]
  organisation      ChantierOrganisation?
  objectifs         ChantierObjectif[]
  dossierExpertises DossierExpertise[]
  siteActions       Action[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([client])
  @@index([status])
  @@index([team])
  @@map("chantier")
}

model ChantierDetails {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client                 String?
  finalClient            String?    @map("final_client")
  address                String?
  contact                String?
  responsible            String?
  architecturalDesign    String?    @map("architectural_design")
  startDate              DateTime?  @map("start_date") @db.Timestamp(6)
  expectedEndDate        DateTime?  @map("expected_end_date") @db.Timestamp(6)
  offerSubmissionDate    DateTime?  @map("offer_submission_date") @db.Timestamp(6)
  responseDeadline       DateTime?  @map("response_deadline") @db.Time(6)
  targetDateSMACWork     DateTime?  @map("target_date_smac_work") @db.Timestamp(6)
  marketType             String?    @map("market_type")
  chantierType           String?    @map("chantier_type")
  siteVisit              Boolean    @default(false) @map("site_visit")
  clusterQuote           String?    @map("cluster_quote")
  needDelegatedAuthority Boolean    @default(false) @map("need_delegated_authority")
  technicity             String?
  linkToAo               String?    @map("link_to_ao")
  technicalDescription   String?    @map("technical_description")
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  chantier               Chantier[]

  @@map("chantier_details")
}

// ── Intervenants ─────────────────────────────────────────────────────────────

model Intervenant {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  typePole        String              @map("type_pole")
  numSAP          Int                 @unique @map("num_sap")
  typeIntervenant TypeIntervenantEnum @map("type_intervenant")
  nom             String              @db.VarChar(100)
  prenom          String              @db.VarChar(100)
  fullName        String              @map("full_name")
  matricule       String?             @db.VarChar(50)
  phone           String?             @map("telephone") @db.VarChar(20)
  qualification   String?             @db.VarChar(100)
  mail            String?             @unique @map("email")
  idAgence        String              @map("id_agence") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime            @default(now()) @map("updated_at") @db.Timestamp(6)
  agence          Agence              @relation(fields: [idAgence], references: [id])
  interventions   Intervention[]

  address   String?
  chantiers ChantierIntervenant[]
  actions   Action[]

  @@index([typePole])
  @@index([idAgence])
  @@index([typeIntervenant])
  @@index([matricule])
  @@map("intervenant")
}

model ChantierIntervenant {
  chantierId    String      @map("chantier_id") @db.Uuid
  intervenantId String      @map("intervenants_id") @db.Uuid
  chantier      Chantier    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  intervenant   Intervenant @relation(fields: [intervenantId], references: [id], onDelete: Cascade)

  @@id([chantierId, intervenantId])
  @@map("chantier_intervenants")
}

// ── Actions ────────────────────────────────────────────────────────────────────

model Action {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anomalyRef       String?           @map("anomaly_ref")
  correctiveAction String?           @map("corrective_action")
  idResponsible    String            @map("id_responsible") @db.Uuid
  idChantier       String            @map("id_chantier") @db.Uuid
  startDate        DateTime?         @map("start_date") @db.Timestamp(6)
  dueDate          DateTime?         @map("due_date") @db.Timestamp(6)
  status           ProcessStatusEnum @default(Initialise)
  criticite        ActionCriticite   @default(MOYEN) @map("criticite")
  photos           String[]
  progress         Int?
  childIndex       Int?              @map("child_index")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  chantiers        ChantierAction[]
  children         ActionChild[]     @relation("parent")
  childOf          ActionChild[]     @relation("child")
  previousOf       ActionPrevious[]  @relation("action")
  predecessors     ActionPrevious[]  @relation("previous")
  responsible      Intervenant       @relation(fields: [idResponsible], references: [id])
  chantier         Chantier          @relation(fields: [idChantier], references: [id], onDelete: Cascade)

  @@index([idResponsible])
  @@index([idChantier])
  @@index([status])
  @@map("action")
}

model ChantierAction {
  chantierId String   @map("chantier_id") @db.Uuid
  actionId   String   @map("actions_id") @db.Uuid
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  action     Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@id([chantierId, actionId])
  @@map("chantier_actions")
}

model ActionChild {
  actionId   String @map("action_id") @db.Uuid
  childrenId String @map("children_id") @db.Uuid
  parent     Action @relation("parent", fields: [actionId], references: [id], onDelete: Cascade)
  child      Action @relation("child", fields: [childrenId], references: [id], onDelete: Cascade)

  @@id([actionId, childrenId])
  @@map("action_children")
}

model ActionPrevious {
  actionId   String @map("action_id") @db.Uuid
  previousId String @map("previous_id") @db.Uuid
  action     Action @relation("action", fields: [actionId], references: [id], onDelete: Cascade)
  previous   Action @relation("previous", fields: [previousId], references: [id], onDelete: Cascade)

  @@id([actionId, previousId])
  @@map("action_previous")
}

// ── Action Criticité ──────────────────────────────────────────────────────────

enum ActionCriticite {
  FAIBLE   @map("faible")
  MOYEN    @map("moyen")
  ELEVE    @map("eleve")
  CRITIQUE @map("critique")

  @@map("action_criticite")
}

// ── Mode Affectation Intervention ────────────────────────────────────────────────────────────

enum ModeAffectationIntervention {
  PC     @map("pc")
  MOBILE @map("mobile")

  @@map("mode_affectation_intervention")
}

// ── Process Status ────────────────────────────────────────────────────────────

enum ProcessStatusEnum {
  Planifie    @map("Planifié")
  Initialise  @map("Initialisé")
  EnCours     @map("En cours")
  EnAttente   @map("En attente")
  PasCommence @map("Pas commencé")
  Termine     @map("Terminé")
  Traite     @map("Traité")
  Annule      @map("Annulé")
  Accepte     @map("Accepté")
  Refuse      @map("Refusé")

  @@map("process_status_enum")
}

// ── Chantier Documentation ────────────────────────────────────────────────────

enum ChantierDocumentationStatus {
  ToDeposit  @map("À Déposer")
  Deposited  @map("Déposé")
  InProgress @map("En cours")
  Archived   @map("Archivé")

  @@map("chantier_documentation_status")
}

enum ChantierDocumentationMotif {
  TRANSFERT_AFFAIRE                @map("transfert-affaire")
  ETUDE_EXECUTION                  @map("etude-execution")
  DOCUMENT_ETUDE                   @map("document-etude")
  SUIVI_VISA                       @map("suivi-visa")
  VISA                             @map("visa")
  BTE_OBJECTIF                     @map("bte-objectif")
  BTE_VERSION                      @map("bte-version")
  BTE_VALIDATION                   @map("bte-validation")
  DOCUMENTAIRE_LANCEMENT           @map("documentaire-lancement")
  DOCUMENT_LANCEMENT               @map("document-lancement")
  EXECUTION                        @map("execution")
  DOCUMENT_RECEPTION               @map("document-reception")
  CLOTURE_AFFAIRE                  @map("cloture-affaire")
  FINANCIAL_MONITORING             @map("financial-monitoring")
  FINANCIAL_MONITORING_CAUTION     @map("financial-monitoring/caution")
  FINANCIAL_MONITORING_FACTURATION @map("financial-monitoring/facturation")
  GUARANTEE_GPA                    @map("guarantee-gpa")
  GUARANTEE_DECENNALE              @map("guarantee-decennale")

  @@map("chantier_documentation_motif")
}

model ChantierDocumentation {
  id                    String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chantierId            String                      @map("chantier_id") @db.Uuid
  authorId              String                      @map("author_id") @db.Uuid
  motif                 ChantierDocumentationMotif
  status                ChantierDocumentationStatus
  path                  String
  fileName              String                      @map("file_name")
  fileNameWithExtension String                      @map("file_name_with_extension")
  type                  String
  size                  Float
  endDate               DateTime?                   @map("end_date") @db.Timestamptz(6)
  folderId              String?                     @map("folder_id") @db.Uuid
  version               Int?
  validateur            String?
  commentaire           String?
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  chantier              Chantier                    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  author                User                        @relation(fields: [authorId], references: [id])
  folder                Folder?                     @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([chantierId])
  @@index([motif])
  @@index([folderId])
  @@map("chantier_documentation")
}

model ChantierRequiredDoc {
  chantierId String   @map("chantier_id") @db.Uuid
  docKey     String   @map("doc_key")
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([chantierId, docKey])
  @@map("chantier_required_doc")
}

model ChantierSharedDoc {
  chantierId String   @map("chantier_id") @db.Uuid
  docKey     String   @map("doc_key")
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([chantierId, docKey])
  @@map("chantier_shared_doc")
}

model ChantierOrganisation {
  chantierId                String   @id @map("chantier_id") @db.Uuid
  heureDepart               String?  @map("heure_depart")
  heureFin                  String?  @map("heure_fin")
  cles                      String?  @map("cles")
  badges                    String?  @map("badges")
  papiersIdentite           String?  @map("papiers_identite")
  posteControle             String?  @map("poste_controle")
  acces                     String?  @map("acces")
  miseEnOeuvre              String?  @map("mise_en_oeuvre")
  manutention               String?  @map("manutention")
  materielManutentionLevage String?  @map("materiel_manutention_levage")
  precautionsParticulieres  String?  @map("precautions_particulieres")
  demarragePrevisionnelLe   String?  @map("demarrage_previsionnel_le")
  finPrevisionnelLe         String?  @map("fin_previsionnel_le")
  tacheExecutee             String?  @map("tache_executee")
  quantite                  String?  @map("quantite")
  tempsPrevus               String?  @map("temps_prevus")
  chantier                  Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("chantier_organisation")
}

model ChantierObjectif {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chantierId String   @map("chantier_id") @db.Uuid
  objectif   String
  tache      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@index([chantierId])
  @@map("chantier_objectif")
}

model Folder {
  id         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  chantierId String                  @map("chantier_id") @db.Uuid
  parentId   String?                 @map("parent_id") @db.Uuid
  chantier   Chantier                @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  parent     Folder?                 @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children   Folder[]                @relation("FolderChildren")
  documents  ChantierDocumentation[]
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([chantierId])
  @@index([parentId])
  @@map("folder")
}

// ── Misc ─────────────────────────────────────────────────────────────────────

model RequestLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientIp  String?  @map("client_ip")
  method    String?
  uri       String?
  protocol  String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("request_log")
}

// ── SMAC DB ── Agence / Etablissement / Intervenant ──────────────────────────

enum TypeIntervenantEnum {
  ConducteurTravaux    @map("conducteur_travaux")
  CompagnonResponsable @map("compagnon_responsable")

  @@map("type_intervenant_enum")
}

enum TypeDocEnum {
  FicheApri                               @map("fiche-apri")
  Mmt                                     @map("mmt")
  Ppsps                                   @map("ppsps")
  EtatsLieux                              @map("etat-lieux")
  FeuilleEmargement                       @map("feuille-emargement")
  FicheStarter                            @map("starter")
  FicheVerificationFourgon                @map("verif-fourg")
  NoticeEPI                               @map("notice-epi")
  PVMiseEau                               @map("pv-mise-eau")
  PVReceptionBetonCharpenteCouverture     @map("pv-recep-beton-charp-couv")
  PVReceptionBetonCharpenteBardage        @map("pv-recep-beton-charp-bard")
  PVReceptionBetonFacade                  @map("pv-recep-beton-fac")
  PVReceptionCharpenteMetalBoisBardage    @map("pv-recep-charp-met-bois-bard")
  PVReceptionCharpenteMetalBoisCouverture @map("pv-recep-charp-met-bois-couv")
  PVReceptionEtancheite                   @map("pv-recep-etan")
  PVReceptionOuvrageArt                   @map("pv-recep-ouv-art")
  PVReceptionSupportsBetonVoirie          @map("pv-recep-sup-beton-voir")
  PVReceptionOuvragesSousTraites          @map("pv-recep-ouv-sous-traites")
  VisitePrevention                        @map("visite-prev")
  FicheVerificationJournaliereEchafaudage @map("verif-journ-echaf")
  VerificationAvantMiseServiceEchafaudage @map("verif-avant-mise-serv-echaf")
  PVReceptionBetonTerrasse                @map("pv-recep-beton-ter")

  @@map("type_doc_enum")
}

enum StatutAoEnum {
  EnCours @map("en_cours")
  Gagne   @map("gagne")
  Perdu   @map("perdu")
  Annule  @map("annule")

  @@map("statut_ao_enum")
}

model Agence {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @map("id_agence") @db.Uuid
  codeAgence         String          @unique @map("code_agence") @db.VarChar(20)
  nomAgence          String          @map("nom_agence") @db.VarChar(150)
  adresseResponsable String?         @map("adresse_responsable")
  adresseDirecteur   String?         @map("adresse_directeur")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime        @default(now()) @map("updated_at") @db.Timestamp(6)
  etablissements     Etablissement[]
  intervenants       Intervenant[]
  chantiers          Chantier[]

  @@map("agence")
}

model Etablissement {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @map("id_etablissement") @db.Uuid
  codeEtablissement String   @unique @map("code_etab") @db.VarChar(20)
  nomEtablissement  String   @map("nom_etab") @db.VarChar(150)
  adresse1          String   @map("adresse_1") @db.VarChar(255)
  adresse2          String?  @map("adresse_2") @db.VarChar(255)
  codePostal        String?  @map("code_postal") @db.VarChar(10)
  ville             String?  @db.VarChar(100)
  telephone         String?  @db.VarChar(20)
  email             String?  @db.VarChar(150)
  codeSap           String?  @map("code_sap") @db.VarChar(50)
  idAgence          String?  @map("id_agence") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  agence            Agence?  @relation(fields: [idAgence], references: [id])
  persons           Person[]

  @@index([idAgence])
  @@map("etablissement")
}

// ── AO (Appel d'Offres) ───────────────────────────────────────────────────────

model Ao {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @map("id_ao") @db.Uuid
  referenceAo   String       @unique @map("reference_ao") @db.VarChar(100)
  intitule      String?      @db.VarChar(255)
  dateEmission  DateTime?    @map("date_emission") @db.Date
  dateLimite    DateTime?    @map("date_limite") @db.Date
  montantEstime Decimal?     @map("montant_estime") @db.Decimal(15, 2)
  statut        StatutAoEnum @default(EnCours)
  idVecteur     String?      @map("id_vecteur") @db.VarChar(100)
  dateSynchro   DateTime?    @map("date_synchro") @db.Timestamp(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime     @default(now()) @map("updated_at") @db.Timestamp(6)
  chantiers     Chantier[]

  @@index([statut])
  @@index([idVecteur])
  @@map("ao")
}

model Intervention {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @map("id_intervention") @db.Uuid
  idIntervenant   String        @map("id_intervenant") @db.Uuid
  idDocumentation String?        @map("id_documentation") @db.Uuid
  idChantier      String        @map("id_chantier") @db.Uuid
  dateAssignation DateTime      @map("date_assignation") @db.Date
  description     String?
  mode            ModeAffectationIntervention @default(PC)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamp(6)
