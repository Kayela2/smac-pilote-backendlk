  updatedAt                               DateTime                                 @default(now()) @map("updated_at") @db.Timestamp(6)
  chantier                                Chantier                                 @relation(fields: [idChantier], references: [id])
  ficheApri                               FicheApri?
  mmt                                     Mmt?
  ppsps                                   Ppsps?
  etatsLieux                              EtatsLieux?
  feuilleEmargement                       FeuilleEmargement?
  ficheStarter                            FicheStarter?
  ficheVerificationFourgon                FicheVerificationFourgon?
  noticeEpi                               NoticeEpi?
  pvMiseEau                               PvMiseEau?
  pvReceptionBetonCharpenteCouverture     PvReceptionBetonCharpenteCouverture?
  pvReceptionBetonCharpenteBardage        PvReceptionBetonCharpenteBardage?
  pvReceptionBetonFacade                  PvReceptionBetonFacade?
  pvReceptionCharpenteMetalBoisBardage    PvReceptionCharpenteMetalBoisBardage?
  pvReceptionCharpenteMetalBoisCouv       PvReceptionCharpenteMetalBoisCouverture?
  pvReceptionEtancheite                   PvReceptionEtancheite?
  pvReceptionOuvrageArt                   PvReceptionOuvrageArt?
  pvReceptionSupportsBetonVoirie          PvReceptionSupportsBetonVoirie?
  pvReceptionOuvragesSousTraites          PvReceptionOuvragesSousTraites?
  visitePrevention                        VisitePrevention?
  ficheVerifJournaliereEchafaudage        FicheVerifJournaliereEchafaudage?
  verificationAvantMiseServiceEchafaudage VerificationAvantMiseServiceEchafaudage?
  pvTerrasse                              PVTerrasse?
  documents                               Document[]
  reserves                                Reserve[]
  interventions                           Intervention[]
  participants                            Participant[]

  @@index([idChantier])
  @@index([typeDoc])
  @@index([idChantier, typeDoc])
  @@map("documentation")
}

