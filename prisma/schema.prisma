// ── Dossiers d'Expertise ─────────────────────────────────────────────────────

enum TypeGarantieEnum {
  GPA       @map("gpa")
  Decennale @map("decennale")

  @@map("type_garantie_enum")
}

enum StatutDossierEnum {
  EnCours @map("en_cours")
  Cloture @map("cloture")

  @@map("statut_dossier_enum")
}

model DossierExpertise {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference       String            @unique
  idChantier      String            @map("id_chantier") @db.Uuid
  typeGarantie    TypeGarantieEnum  @map("type_garantie")
  objet           String
  expertDesigne   String?           @map("expert_designe")
  avocatSmac      String?           @map("avocat_smac")
  dateOuverture   DateTime          @map("date_ouverture") @db.Date
  statut          StatutDossierEnum @default(EnCours)
  juridiction     String?
  dateAssignation DateTime?         @map("date_assignation") @db.Date
  demandeur       String?
  defendeurs      String?
  griefs          String?
  chantier        Chantier          @relation(fields: [idChantier], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([statut])
  @@map("dossier_expertise")
}

model Reserve {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @map("id_reserve") @db.Uuid
  idDocumentation String        @map("id_documentation") @db.Uuid
  images          Json          @default("[]") // max 6 images — enforce in application layer (DB-level CHECK not supported by Prisma)
  localisation    String?
  details         String
  documentation   Documentation @relation(fields: [idDocumentation], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([idDocumentation])
  @@map("reserve")
}
