{
	"name": "smac-pilote-server",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Node/Express + PostgreSQL API for SMAC-PILOTE",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"db:seed": "tsx src/db/seed.ts",
		"db:migrate": "prisma migrate deploy --config prisma.config.ts",
		"db:push": "prisma db push --config prisma.config.ts",
		"db:generate": "prisma generate --config prisma.config.ts",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@azure/storage-blob": "^12.31.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@types/cookie-parser": "^1.4.8",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.10.5",
		"@types/pg": "^8.11.10",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"bcryptjs": "^3.0.2",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"jsonwebtoken": "^9.0.2",
		"multer": "2.1.1",
		"pg": "^8.13.1",
		"prisma": "^7.8.0",
		"swagger-jsdoc": "^6.3.0",
		"swagger-ui-express": "^5.0.1",
		"typescript": "^5.7.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.4.1",
		"tsx": "^4.19.2",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.7"
	}
}
