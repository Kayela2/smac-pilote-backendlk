{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*.ts"
	]
}
